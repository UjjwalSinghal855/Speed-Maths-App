<?xml version="1.0" encoding="utf-8"?>
<!-- Result screen shown after each practice session -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- ── Summary Header Card ────────────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp" app:cardElevation="4dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <TextView android:id="@+id/tvPerformance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="⭐ Excellent!"
                android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:gravity="center" android:paddingBottom="12dp"/>

            <!-- Stats grid: 3×2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvTotalQ" android:text="20"/>
                    <TextView style="@style/StatLabel" android:text="Questions"/>
                </LinearLayout>
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvCorrect"
                        android:text="18" android:textColor="@color/correct_green"/>
                    <TextView style="@style/StatLabel" android:text="Correct"/>
                </LinearLayout>
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvWrong"
                        android:text="2" android:textColor="@color/error_red"/>
                    <TextView style="@style/StatLabel" android:text="Wrong"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvAccuracy" android:text="90.0%"/>
                    <TextView style="@style/StatLabel" android:text="Accuracy"/>
                </LinearLayout>
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvTotalTime" android:text="1:45"/>
                    <TextView style="@style/StatLabel" android:text="Total Time"/>
                </LinearLayout>
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvAvgTime" android:text="5.2s"/>
                    <TextView style="@style/StatLabel" android:text="Avg/Q"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Action Buttons ─────────────────────────────────────────────────── -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btnHome"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="🏠 Home" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnProgress"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="📊 Stats" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnPracticeAgain"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="🔁 Again"
            android:backgroundTint="@color/primary_blue"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- ── Question-by-question review list ──────────────────────────────── -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Question Review"
        android:textSize="14sp" android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:paddingStart="16dp" android:paddingBottom="6dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvQuestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
