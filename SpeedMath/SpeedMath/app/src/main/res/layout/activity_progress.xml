<?xml version="1.0" encoding="utf-8"?>
<!-- Progress / Analytics Dashboard screen -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="← Back"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="📊 My Progress"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/text_primary" android:gravity="center"/>
            <Button android:id="@+id/btnClearData"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Clear" android:textColor="@color/error_red"/>
        </LinearLayout>

        <!-- ── Overview Stats ─────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Lifetime Stats" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:paddingBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout style="@style/StatCell">
                        <TextView style="@style/StatValue" android:id="@+id/tvTotalSessions" android:text="0"/>
                        <TextView style="@style/StatLabel" android:text="Sessions"/>
                    </LinearLayout>
                    <LinearLayout style="@style/StatCell">
                        <TextView style="@style/StatValue" android:id="@+id/tvOverallAccuracy" android:text="0%"/>
                        <TextView style="@style/StatLabel" android:text="Accuracy"/>
                    </LinearLayout>
                    <LinearLayout style="@style/StatCell">
                        <TextView style="@style/StatValue" android:id="@+id/tvAvgSpeed" android:text="—"/>
                        <TextView style="@style/StatLabel" android:text="Avg Speed"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Streak Card ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp">
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvCurrentStreak"
                        android:text="0 days 🔥" android:textSize="16sp"/>
                    <TextView style="@style/StatLabel" android:text="Current Streak"/>
                </LinearLayout>
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvBestStreak"
                        android:text="0 days" android:textSize="16sp"/>
                    <TextView style="@style/StatLabel" android:text="Best Streak"/>
                </LinearLayout>
                <LinearLayout style="@style/StatCell">
                    <TextView style="@style/StatValue" android:id="@+id/tvBestSession"
                        android:text="—" android:textSize="11sp"/>
                    <TextView style="@style/StatLabel" android:text="Best Session"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Accuracy Chart ─────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Accuracy Over Time (%)"
                    android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:paddingBottom="8dp"/>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartAccuracy"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Speed Chart ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp" app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Speed Improvement (sec/question)"
                    android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/text_primary" android:paddingBottom="8dp"/>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
