<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        SpeedMath – 100% Offline Application
        NO internet permission is declared. All data is local (Room DB + SharedPreferences).
    -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpeedMath">

        <!-- ── 1. Home Screen ──────────────────────────────────────────────── -->
        <activity
            android:name=".ui.home.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── 2. Settings / Configure Session ───────────────────────────── -->
        <activity android:name=".ui.settings.SettingsActivity" />

        <!-- ── 3. Practice Screen ─────────────────────────────────────────── -->
        <!-- adjustResize so the keyboard doesn't cover the answer input -->
        <activity
            android:name=".ui.practice.PracticeActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── 4. Results Screen ──────────────────────────────────────────── -->
        <activity android:name=".ui.result.ResultActivity" />

        <!-- ── 5. Progress Dashboard ──────────────────────────────────────── -->
        <activity android:name=".ui.progress.ProgressActivity" />

    </application>

</manifest>
